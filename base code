<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio | Portfolio Preview</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&family=Playfair+Display:ital,wght@0,400;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --main-bg: #ffffff;
            --text-dark: #121212;
            --accent: #8e8e8e;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
            line-height: 1.6;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 30px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
        }

        .logo { 
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem; 
            font-weight: 700;
            letter-spacing: 1px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-dark);
            margin-left: 30px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: var(--transition);
        }

        .nav-links a:hover { color: var(--accent); }

        /* Hero Section with Vimeo Placeholder */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 0 5%;
            text-align: center;
        }

        .hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 8vw, 4rem);
            margin-bottom: 20px;
        }

        .video-wrapper {
            width: 100%;
            max-width: 1100px;
            aspect-ratio: 16 / 9;
            background: #000;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            position: relative;
        }

        /* Portfolio Grid */
        .work-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
            padding: 20px;
        }

        .project-card {
            position: relative;
            height: 500px;
            overflow: hidden;
            background: #f4f4f4;
        }

        .project-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
            filter: grayscale(20%);
        }

        .project-card:hover img {
            transform: scale(1.05);
            filter: grayscale(0%);
        }

        .project-info {
            position: absolute;
            bottom: 30px;
            left: 30px;
            color: white;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
        }

        /* Contact Section with Google Form Link */
        .contact-section {
            padding: 150px 5%;
            text-align: center;
        }

        .contact-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            margin-bottom: 40px;
        }

        .btn-link {
            display: inline-block;
            padding: 18px 45px;
            border: 1px solid var(--text-dark);
            text-decoration: none;
            color: var(--text-dark);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 3px;
            transition: var(--transition);
        }

        .btn-link:hover {
            background: var(--text-dark);
            color: white;
        }

        footer {
            padding: 50px;
            text-align: center;
            font-size: 0.7rem;
            letter-spacing: 1px;
            color: var(--accent);
            text-transform: uppercase;
        }

        @media (max-width: 600px) {
            .work-grid { grid-template-columns: 1fr; }
            .project-card { height: 300px; }
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">ELIJAH STYLE</div>
        <div class="nav-links">
            <a href="#work">Work</a>
            <a href="#contact">Contact</a>
        </div>
    </nav>

    <header class="hero">
        <h1>Cinematography & Design</h1>
        <div class="video-wrapper">
            <iframe src="https://player.vimeo.com/video/76979871?h=0&title=0&byline=0&portrait=0" 
                    style="position:absolute;top:0;left:0;width:100%;height:100%;" 
                    frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
        </div>
    </header>

    <section id="work" class="work-grid">
        <div class="project-card">
            <img src="https://images.unsplash.com/photo-1492691523567-6170c817538a?auto=format&fit=crop&w=800&q=80" alt="Work 1">
            <div class="project-info"><h3>Project One</h3><p>Visual Narrative</p></div>
        </div>
        <div class="project-card">
            <img src="https://images.unsplash.com/photo-1550684848-fac1c5b4e853?auto=format&fit=crop&w=800&q=80" alt="Work 2">
            <div class="project-info"><h3>Project Two</h3><p>Brand Identity</p></div>
        </div>
    </section>

    <section id="contact" class="contact-section">
        <h2>Let's Connect</h2>
        <p style="margin-bottom: 30px; color: var(--accent);">For inquiries and collaborations, please use the form below.</p>
        <a href="https://docs.google.com/forms/u/0/" class="btn-link" target="_blank">Open Inquiry Form</a>
    </section>

    <footer>
        &copy; 2026 Portfolio. Minimalist Design Template.
    </footer>

</body>
</html>
